GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT_MS=12000
GEMINI_RETRY_COUNT=1
ANALYZE_RATE_LIMIT_MAX=30

# Groq text-normalization API (used by POST /api/text/process)
# Get your key at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
# Available models: llama3-8b-8192, llama3-70b-8192, mixtral-8x7b-32768
GROQ_MODEL=llama3-8b-8192
GROQ_TIMEOUT_MS=12000
GROQ_RETRY_COUNT=1
TEXT_PROCESS_RATE_LIMIT_MAX=30
